# Duplikat-Check: Erkennt Instanzen, die unter einem fremden Namespace
# angelegt wurden, obwohl ein identisches Konzept bereits im Glossar existiert.
#
# Ausführung (alle Graphdateien übergeben):
#   node .agents/skills/sparql-query/scripts/query.js \
#     --file graph/glossary.ttl \
#     --file graph/versand.ttl \
#     --file graph/zahlungsmethoden.ttl \
#     --query queries/glossary/duplikat-check.rq
#
# Erwartetes Ergebnis bei korrektem Punning: 0 Zeilen
#
# Anti-Pattern das erkannt wird:
#   zahlung:Kreditkarte a :Zahlungsmethode   ← falscher Namespace
#   statt: :Kreditkarte a owl:NamedIndividual ← korrektes Punning

PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX :     <https://shop.example.org/glossary#>

SELECT DISTINCT ?duplikat ?glossarKonzept ?glossarLabel WHERE {
  # Eine Instanz außerhalb des Glossar-Namespace ...
  ?duplikat a owl:NamedIndividual .
  FILTER(!STRSTARTS(STR(?duplikat), "https://shop.example.org/glossary#"))

  # ... hat denselben rdfs:label oder skos:prefLabel wie ein Glossar-Konzept
  { ?duplikat rdfs:label ?name }
  UNION
  { ?duplikat skos:prefLabel ?name }

  ?glossarKonzept a skos:Concept ;
                  skos:prefLabel ?glossarLabel .
  FILTER(LCASE(STR(?name)) = LCASE(STR(?glossarLabel)))
}
ORDER BY ?glossarLabel
