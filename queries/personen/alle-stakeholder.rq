# Alle Stakeholder mit Namen, Rolle und Beschreibung
#
# Benötigt alle Personendateien. Einfachste Variante: eine Datei übergeben,
# da cross-file-Joins Comunica mehrere --file-Argumente benötigen würden.
# Hier: gegen _vocab.ttl + eine Personendatei testen, oder alle zusammenführen.
#
# Ausführen (alle Personen-TTLs auf einmal):
#   node .agents/skills/sparql-query/scripts/query.js \
#     --file graph/personen/thomas.ttl \
#     --file graph/personen/sarah.ttl \
#     --file graph/personen/julia.ttl \
#     --file graph/personen/lena.ttl \
#     --file graph/personen/marco.ttl \
#     --query queries/personen/alle-stakeholder.rq

PREFIX foaf:   <http://xmlns.com/foaf/0.1/>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dct:    <http://purl.org/dc/terms/>
PREFIX org:    <http://www.w3.org/ns/org#>

SELECT ?person ?label ?beschreibung
WHERE {
  ?person a foaf:Person ;
          rdfs:label ?label .
  OPTIONAL { ?person dct:description ?beschreibung . }
}
ORDER BY ?label
