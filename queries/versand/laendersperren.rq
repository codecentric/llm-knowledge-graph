# Alle Ländersperren: welche Produktkategorien sind für welche Länder gesperrt?
#
# Datei: graph/versand.ttl
# Ausführen:
#   node .agents/skills/sparql-query/scripts/query.js \
#     --file graph/versand.ttl \
#     --query queries/versand/laendersperren.rq

PREFIX versand: <https://shop.example.org/versand#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX :        <https://shop.example.org/glossary#>

SELECT ?sperreLabel ?kategorieLabel ?landLabel ?grund ?skuUeberschreibung
WHERE {
  ?sperre a :Landerbeschrankung ;
          rdfs:label ?sperreLabel .
  OPTIONAL {
    ?sperre versand:gesperrteKategorie ?kategorie .
    ?kategorie rdfs:label ?kategorieLabel .
  }
  OPTIONAL {
    ?sperre versand:gesperrtFuerLand ?land .
    ?land rdfs:label ?landLabel .
  }
  OPTIONAL { ?sperre versand:sperrgrund ?grund . }
  OPTIONAL { ?sperre versand:skuUeberschreibungMoeglich ?skuUeberschreibung . }
}
ORDER BY ?sperreLabel
