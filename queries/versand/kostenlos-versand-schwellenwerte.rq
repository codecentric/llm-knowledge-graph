# Kostenloser Versand: Mindest-Warenkorbwert pro Land
#
# Datei: graph/versand.ttl
# Ausführen:
#   node /workspace/.agents/skills/sparql-query/scripts/query.js \
#     --file /workspace/graph/versand.ttl \
#     --query /workspace/queries/versand/kostenlos-versand-schwellenwerte.rq

PREFIX versand: <https://shop.example.org/versand#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema:  <https://schema.org/>
PREFIX dct:     <http://purl.org/dc/terms/>

SELECT ?landName ?isoCode ?schwellenwert ?hinweis
WHERE {
  ?land a versand:Land ;
        rdfs:label ?landName ;
        versand:kostenlosAbWarenkorbwert ?schwellenwert .
  OPTIONAL { ?land schema:identifier ?isoCode . }
  OPTIONAL { ?land dct:description ?hinweis . }
}
ORDER BY ?schwellenwert
