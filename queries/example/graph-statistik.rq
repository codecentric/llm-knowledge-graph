# Überblick: Tripel, Klassen, Konzepte
# Ausführen: node .agents/skills/sparql-query/scripts/query.js --file graph/glossar.ttl --query queries/example/graph-statistik.rq

PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT
  (COUNT(?s) AS ?tripel)
  (COUNT(DISTINCT ?klasse) AS ?klassen)
  (COUNT(DISTINCT ?konzept) AS ?konzepte)
WHERE {
  { ?s ?p ?o }
  OPTIONAL { ?klasse a owl:Class }
  OPTIONAL { ?konzept a skos:Concept }
}
