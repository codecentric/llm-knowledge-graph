@prefix person: <https://shop.example.org/personen#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix org:    <http://www.w3.org/ns/org#> .

# =============================================================================
# personen/_vocab.ttl – gemeinsames Vokabular für alle Personendokumente
# =============================================================================

<https://shop.example.org/personen> a owl:Ontology ;
    dct:title       "Personen – Shop-Projekt"@de ;
    dct:description "Stakeholder, Rollen, Entscheidungen und offene Fragen aus den Quelldokumenten des Shop-Projekts."@de ;
    dct:created     "2026-05-08"^^xsd:date .

# --- Klassen -----------------------------------------------------------------

person:Entscheidung a owl:Class ;
    rdfs:label   "Entscheidung"@de ;
    rdfs:comment "Eine getroffene, dokumentierte Fachentscheidung mit Urheber, Datum und Quelle."@de .

person:OffeneFrage a owl:Class ;
    rdfs:label   "Offene Frage"@de ;
    rdfs:comment "Eine im Verlauf von Meetings oder Chats aufgeworfene Frage, die beantwortet wurde oder noch offen ist."@de .

# --- Properties --------------------------------------------------------------

person:hatEntschieden a owl:ObjectProperty ;
    rdfs:domain  foaf:Person ;
    rdfs:label   "hat entschieden"@de ;
    rdfs:comment "Verknüpft eine Person mit einer Entscheidung oder Ressource, die sie final verantwortet hat."@de .

person:hatEingebracht a owl:ObjectProperty ;
    rdfs:domain  foaf:Person ;
    rdfs:label   "hat eingebracht"@de ;
    rdfs:comment "Verknüpft eine Person mit Inhalten (Instanzen, Regeln), die sie in die Diskussion eingebracht hat."@de .

person:hatInitiiert a owl:ObjectProperty ;
    rdfs:domain  foaf:Person ;
    rdfs:range   person:OffeneFrage ;
    rdfs:label   "hat initiiert"@de ;
    rdfs:comment "Verknüpft eine Person mit einer Frage, die sie gestellt hat."@de .

person:hatFestgehalten a owl:ObjectProperty ;
    rdfs:domain  foaf:Person ;
    rdfs:label   "hat festgehalten"@de ;
    rdfs:comment "Verknüpft eine Person mit einem Dokument, das sie erstellt oder als Protokoll geführt hat."@de .

person:hatOffenePunkte a owl:ObjectProperty ;
    rdfs:domain  foaf:Person ;
    rdfs:label   "hat offene Punkte"@de ;
    rdfs:comment "Verknüpft eine Person mit noch ungeklärten Punkten, für die sie verantwortlich ist."@de .

person:beantwortetDurch a owl:DatatypeProperty ;
    rdfs:domain  person:OffeneFrage ;
    rdfs:label   "beantwortet durch"@de .

person:beantwortetVon a owl:ObjectProperty ;
    rdfs:domain  person:OffeneFrage ;
    rdfs:range   foaf:Person ;
    rdfs:label   "beantwortet von"@de .
