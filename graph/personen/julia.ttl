person:Julia a foaf:Person, owl:NamedIndividual ;
    foaf:firstName   "Julia" ;
    foaf:lastName    "unbekannt" ;
    org:role         person:Rolle_Logistik ;
    rdfs:label       "Julia (Logistik)"@de ;
    dct:description  "Verantwortlich für Logistik und Versandpartnerschaften. Hat im Meeting die aktuellen Versandpartner vorgestellt und die Versandkonditionen definiert."@de ;
    dct:source       <inputs/meeting-checkout-versand.md> ;
    person:hatEingebracht
        versand:DHL_Standard ,
        versand:DHL_Express ,
        versand:DPD ,
        versand:SpeditionMuller ,
        versand:Sperre_Messer_UK ,
        versand:Sperre_Lebensmittel .

person:Rolle_Logistik a org:Role ;
    rdfs:label  "Logistik"@de .
