@prefix :       <https://shop.example.org/glossary#> .
@prefix person: <https://shop.example.org/personen#> .
@prefix versand: <https://shop.example.org/versand#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix org:    <http://www.w3.org/ns/org#> .

person:Sarah a foaf:Person, owl:NamedIndividual ;
    foaf:firstName   "Sarah" ;
    foaf:lastName    "unbekannt" ;
    org:role         person:Rolle_ProductOwner ;
    rdfs:label       "Sarah (Product Owner)"@de ;
    dct:description  "Product Owner des Shop-Projekts. Moderiert Meetings, hält Entscheidungen fest und ist fachlich verantwortlich für Rabattlogik und Checkout-Regeln."@de ;
    dct:source       <inputs/meeting-checkout-versand.md>,
                     <inputs/slack-export-preisregeln.md> ;
    person:hatEntschieden
        versand:Sperre_Messer_UK,        # kategoriebasiert mit SKU-Überschreibung
        versand:Sperre_Lebensmittel ;
    person:hatFestgehalten
        <inputs/meeting-checkout-versand.md> .   # Protokollführerin

person:Rolle_ProductOwner a org:Role ;
    rdfs:label  "Product Owner"@de ;
    skos:altLabel "PO"@de .
