@prefix :       <https://shop.example.org/glossary#> .
@prefix person: <https://shop.example.org/personen#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix org:    <http://www.w3.org/ns/org#> .

person:Lena a foaf:Person, owl:NamedIndividual ;
    foaf:firstName   "Lena" ;
    foaf:lastName    "Fischer" ;
    org:role         person:Rolle_Finance ;
    rdfs:label       "Lena Fischer (Finance)"@de ;
    dct:description  "Finance-Verantwortliche. Hat steuerlich relevante Rabattausschlüsse für Lebensmittel und digitale Produkte eingebracht und die Bundle-Rabattregel final geklärt."@de ;
    dct:source       <inputs/slack-export-preisregeln.md> ;
    person:hatEingebracht
        person:Regel_Rabattfrei_Lebensmittel_Digital ,
        person:Regel_Bundle_Digital_Schwellenwert ;
    person:hatFestgehalten
        <inputs/slack-export-preisregeln.md> .   # Slack-Export erstellt

person:Regel_Rabattfrei_Lebensmittel_Digital a person:Entscheidung ;
    rdfs:label      "Regel: Lebensmittel und digitale Produkte sind rabattfrei"@de ;
    dct:description "Steuerlich begründet. Gilt auch für Treuerabatte. Eingebracht von Lena, bestätigt von Sarah."@de ;
    dct:date        "2024-02-12"^^xsd:date ;
    dct:source      <inputs/slack-export-preisregeln.md> .

person:Regel_Bundle_Digital_Schwellenwert a person:Entscheidung ;
    rdfs:label      "Regel: Bundle rabattfrei wenn digitaler Anteil > 50 % des Bruttopreises"@de ;
    dct:description "Klärt Marcos Frage zu gemischten Bundles. Bei > 50 % digitalem Anteil am Bruttopreis gilt das gesamte Bundle als rabattfrei."@de ;
    dct:date        "2024-02-13"^^xsd:date ;
    dct:source      <inputs/slack-export-preisregeln.md> .

person:Rolle_Finance a org:Role ;
    rdfs:label  "Finance"@de .
