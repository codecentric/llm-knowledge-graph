@prefix : <https://shop.example.org/glossary#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<https://shop.example.org/glossary#> a owl:Ontology;
    dct:title "Shop-Fachglossar: Checkout, Versand & Preisregeln";
    dct:created "2026-05-08"^^xsd:date;
    dct:source "produkte-kategorien.csv", "meeting-checkout-versand.md", "slack-export-preisregeln.md".
:GlossaryScheme a skos:ConceptScheme;
    skos:prefLabel "Shop-Fachglossar: Checkout, Versand & Preisregeln"@de;
    rdfs:comment "Auto-generated by domain-glossary-rdf skill. 47 concept(s). Review and enrich manually.".
:Produktkategorie a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Produktkategorie"@de;
    skos:altLabel "Kategorie"@de;
    skos:definition "Klassifikationseinheit zur Gruppierung von Produkten im Shop-System, kann einer übergeordneten Kategorie zugeordnet sein."@de;
    skos:related :SKU, :Versandpflichtig.
:Elektronik a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Elektronik"@de;
    skos:definition "Oberste Produktkategorie für elektronische Geräte und Zubehör."@de;
    skos:broader :Produktkategorie;
    skos:related :Smartphones, :Laptops, :Gaming.
:Smartphones a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Smartphones"@de;
    skos:definition "Unterkategorie von Elektronik für mobile Endgeräte."@de;
    skos:broader :Elektronik;
    skos:related :Laptops.
:Laptops a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Laptops"@de;
    skos:definition "Unterkategorie von Elektronik für tragbare Computer."@de;
    skos:broader :Elektronik;
    skos:related :Smartphones.
:Software a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Software"@de;
    skos:definition "Produktkategorie für Softwareprodukte; Typ und Elternkategorie noch ungeklärt, wird digital geliefert."@de;
    skos:broader :Produktkategorie;
    skos:related :Digitales_Produkt, :Gaming_Downloads.
:E-Books a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "E-Books"@de;
    skos:definition "Digitale Produktkategorie für elektronische Bücher, wird ausschließlich digital geliefert."@de;
    skos:broader :Digitales_Produkt;
    skos:related :Software.
:Gaming a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Gaming"@de;
    skos:altLabel "Konsolen und Zubehör"@de;
    skos:definition "Unterkategorie von Elektronik für Spielkonsolen und Zubehör (physische Artikel)."@de;
    skos:broader :Elektronik;
    skos:related :Gaming_Downloads.
:Gaming_Downloads a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Gaming Downloads"@de;
    skos:definition "Digitale Unterkategorie von Gaming für herunterladbare Spiele und Inhalte; mögliche Überschneidung mit Software."@de;
    skos:broader :Gaming;
    skos:related :Software, :Digitales_Produkt.
:Kleidung a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Kleidung"@de;
    skos:definition "Physische Produktkategorie für Bekleidung."@de;
    skos:broader :Produktkategorie;
    skos:related :Schuhe, :Accessoires.
:Schuhe a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Schuhe"@de;
    skos:definition "Physische Unterkategorie von Kleidung für Schuhwaren."@de;
    skos:broader :Kleidung;
    skos:related :Accessoires.
:Accessoires a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Accessoires"@de;
    skos:definition "Physische Unterkategorie von Kleidung; umfasst Schmuck und Taschen."@de;
    skos:broader :Kleidung;
    skos:related :Schuhe.
:Haushalt a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Haushalt"@de;
    skos:definition "Physische Produktkategorie für Haushaltsartikel."@de;
    skos:broader :Produktkategorie;
    skos:related :Mobel, :Sperrgut.
:Mobel a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Möbel"@de;
    skos:definition "Physische Unterkategorie von Haushalt; erfordert gesonderte Versandregeln als Sperrgut."@de;
    skos:broader :Haushalt;
    skos:related :Sperrgut, :Sperrgut.
:Lebensmittel a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Lebensmittel"@de;
    skos:definition "Physische Produktkategorie mit besonderer Behandlung: nur Lieferung in DE und AT, keine Rabatte, ggf. Kühlpflicht."@de;
    skos:broader :Produktkategorie;
    skos:related :Kuhlpflichtiger_Artikel, :Landerbeschrankung, :Rabattfrei.
:Digitales_Produkt a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Digitales Produkt"@de;
    skos:altLabel "digitale Lieferung"@de;
    skos:definition "Produkt, das ausschließlich elektronisch geliefert wird, ohne physischen Versand; generell rabattfrei."@de;
    skos:broader :Produktkategorie;
    skos:related :E-Books, :Software, :Gaming_Downloads, :Rabattfrei.
:Physisches_Produkt a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Physisches Produkt"@de;
    skos:altLabel "physisch"@de;
    skos:definition "Produkt, das als physische Ware versandt wird und der Versandpflicht unterliegt."@de;
    skos:broader :Produktkategorie;
    skos:related :Versandpflichtig, :Versandpartner.
:SKU a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "SKU"@de;
    skos:altLabel "Artikel"@de, "Stock Keeping Unit"@de;
    skos:definition "Eindeutige Identifikationseinheit für ein einzelnes Produkt im System; ermöglicht SKU-spezifische Überschreibung von Kategorie-Regeln."@de;
    skos:related :Produktkategorie, :Landerbeschrankung.
:Warenkorb a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Warenkorb"@de;
    skos:definition "Digitaler Behälter, der die vom Kunden ausgewählten Produkte vor der Bestellung enthält; Grundlage für Rabatt- und Versandberechnungen."@de;
    skos:related :Bestellung, :Warenkorbwert, :Rabattlogik.
:Bestellung a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Bestellung"@de;
    skos:altLabel "Order"@de;
    skos:definition "Abgeschlossener Kaufvorgang eines Kunden; Grundlage für Kundenstatus und Zahlungsartberechtigung."@de;
    skos:related :Warenkorb, :Bestandskunde, :Zahlungsmethode.
:Warenkorbwert a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Warenkorbwert"@de;
    skos:definition "Gesamtsumme aller Artikel im Warenkorb; Schwellenwert für kostenlosen Versand."@de;
    skos:broader :Warenkorb;
    skos:related :Kostenloser_Versand, :Bruttopreis.
:Zahlungsmethode a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Zahlungsmethode"@de;
    skos:altLabel "Zahlungsart"@de;
    skos:definition "Vom Kunden gewähltes Bezahlverfahren beim Checkout; abhängig von Land und Kundenstatus."@de;
    skos:related :Kreditkarte, :PayPal, :Rechnung, :Sofortuberweisung, :Ratenkauf.
:Kreditkarte a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Kreditkarte"@de;
    skos:definition "Zahlungsmethode, die für alle Länder angeboten wird."@de;
    skos:broader :Zahlungsmethode;
    skos:related :PayPal, :Sofortuberweisung.
:PayPal a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "PayPal"@de;
    skos:definition "Zahlungsmethode, verfügbar in EU, UK und Schweiz; außerhalb nicht rentabel wegen Gebühren."@de;
    skos:broader :Zahlungsmethode;
    skos:related :Kreditkarte.
:Rechnung a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Rechnung"@de;
    skos:definition "Zahlungsmethode, die ausschließlich für Bestandskunden ohne offenen Mahnfall verfügbar ist."@de;
    skos:broader :Zahlungsmethode;
    skos:related :Bestandskunde, :Mahnfall.
:Sofortuberweisung a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Sofortüberweisung"@de;
    skos:definition "Zahlungsmethode, die nur in den DACH-Ländern (Deutschland, Österreich, Schweiz) verfügbar ist."@de;
    skos:broader :Zahlungsmethode;
    skos:related :Kreditkarte, :PayPal.
:Ratenkauf a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Ratenkauf"@de;
    skos:definition "Zahlungsmethode, die zunächst aus dem Projekt-Scope ausgenommen wurde."@de;
    skos:broader :Zahlungsmethode.
:Bestandskunde a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Bestandskunde"@de;
    skos:definition "Kunde mit mindestens einer abgeschlossenen Bestellung und ohne offenen Mahnfall; berechtigt zur Zahlung per Rechnung."@de;
    skos:related :Bestellung, :Mahnfall, :Rechnung.
:Mahnfall a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Mahnfall"@de;
    skos:altLabel "offener Mahnfall"@de;
    skos:definition "Kundenstatus mit offenen, überfälligen Forderungen; schließt die Zahlungsart Rechnung aus."@de;
    skos:related :Bestandskunde, :Rechnung.
:Versandpartner a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Versandpartner"@de;
    skos:altLabel "Versandanbieter"@de;
    skos:definition "Externes Logistikunternehmen, das den physischen Warenversand durchführt (z. B. DHL, DPD, Spedition)."@de;
    skos:related :Versandoption, :Lieferzeit, :Landerbeschrankung.
:Versandoption a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Versandoption"@de;
    skos:definition "Konkrete Versandvariante mit definiertem Anbieter, Lieferzeit und Geltungsbereich."@de;
    skos:related :Versandpartner, :Lieferzeit, :Kostenloser_Versand.
:Lieferzeit a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Lieferzeit"@de;
    skos:altLabel "Lieferfrist"@de;
    skos:definition "Zeitspanne zwischen Bestelleingang und Lieferung beim Kunden, angegeben in Werktagen."@de;
    skos:broader :Versandoption;
    skos:related :Versandpartner.
:Kostenloser_Versand a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Kostenloser Versand"@de;
    skos:definition "Versandkostenbefreiung für den Kunden ab einem definierten Warenkorbwert; länderspezifische Schwellenwerte."@de;
    skos:broader :Versandoption;
    skos:related :Warenkorbwert, :Landerbeschrankung.
:Sperrgut a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Sperrgut"@de;
    skos:altLabel "Sperrgut-Versand"@de;
    skos:definition "Großformatige oder schwere physische Artikel (insb. Möbel), für die gesonderte Versandregeln und ein spezieller Versandpartner (Spedition) gelten."@de;
    skos:broader :Physisches_Produkt;
    skos:related :Mobel, :Versandpartner.
:Kuhlpflichtiger_Artikel a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Kühlpflichtiger Artikel"@de;
    skos:altLabel "Kühlware"@de;
    skos:definition "Lebensmittel, die eine Kühlkette während des Versands erfordern; Sonderfall noch offen."@de;
    skos:broader :Lebensmittel;
    skos:related :Versandoption.
:Landerbeschrankung a skos:Concept, owl:Class;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Länderbeschränkung"@de;
    skos:altLabel "Sperrliste"@de;
    skos:definition "Regel, die die Lieferung bestimmter Produktkategorien oder SKUs in bestimmte Länder untersagt (z. B. Messer nach UK, Lebensmittel nur DEAT)."@de;
    skos:related :Produktkategorie, :SKU, :Versandpartner.
:SKU-spezifische_Uberschreibung a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "SKU-spezifische Überschreibung"@de;
    skos:definition "Mechanismus, mit dem kategorie-basierte Regeln (z. B. Länderbeschränkungen) für einzelne Artikel (SKUs) individuell überschrieben werden können."@de;
    skos:broader :Landerbeschrankung;
    skos:related :SKU, :Produktkategorie.
:Rabattlogik a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Rabattlogik"@de;
    skos:altLabel "Preisregel"@de;
    skos:definition "Gesamtheit der Regeln, nach denen Rabatte auf Produkte und Warenkörbe angewendet, kombiniert oder ausgeschlossen werden."@de;
    skos:related :Gutscheincode, :Sale-Angebot, :Treuerabatt, :Rabattfrei.
:Prozentualer_Rabatt a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Prozentualer Rabatt"@de;
    skos:definition "Rabatt, der als prozentualer Abzug vom Preis gewährt wird; maximal einer pro Warenkorb (exkl. Treuerabatt)."@de;
    skos:broader :Rabattlogik;
    skos:related :Gutscheincode, :Sale-Angebot, :Treuerabatt.
:Gutscheincode a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Gutscheincode"@de;
    skos:altLabel "Coupon"@de;
    skos:definition "Kundenindividueller Rabattcode, der pro Bestellung genau einmal eingelöst werden kann; schließt Sale-Angebote aus."@de;
    skos:broader :Prozentualer_Rabatt;
    skos:related :Sale-Angebot, :Rabattlogik.
:Sale-Angebot a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Sale-Angebot"@de;
    skos:altLabel "Sale"@de, "Aktionsrabatt"@de;
    skos:definition "Automatisch angewendetes zeitlich begrenztes Rabattangebot; hat Vorrang gegenüber Gutscheincodes."@de;
    skos:broader :Prozentualer_Rabatt;
    skos:related :Gutscheincode, :Rabattlogik.
:Treuerabatt a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Treuerabatt"@de;
    skos:altLabel "Loyalitätsrabatt"@de;
    skos:definition "Automatisch angewendeter Rabatt basierend auf gesammelten Treuepunkten; kombinierbar mit anderen Rabatten, maximal 10 %."@de;
    skos:broader :Rabattlogik;
    skos:related :Treuepunkte, :Prozentualer_Rabatt.
:Treuepunkte a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Treuepunkte"@de;
    skos:altLabel "Punkte"@de;
    skos:definition "Vom Kunden gesammelte Punkte im Rahmen eines Treueprogramms, die in Treuerabatte umgewandelt werden können."@de;
    skos:related :Treuerabatt, :Bestandskunde.
:Rabattfrei a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Rabattfrei"@de;
    skos:altLabel "keine Rabatte"@de;
    skos:definition "Eigenschaft von Produkten oder Kategorien (Lebensmittel, digitale Produkte), auf die keinerlei Rabatte angewendet werden dürfen – auch kein Treuerabatt; steuerlich begründet."@de;
    skos:broader :Rabattlogik;
    skos:related :Digitales_Produkt, :Lebensmittel.
:Bundle a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Bundle"@de;
    skos:altLabel "Produktbundle"@de, "gemischtes Bundle"@de;
    skos:definition "Kombination mehrerer Produkte (physisch und/oder digital) zu einem Gesamtangebot; Rabattfähigkeit hängt vom Anteil digitaler Inhalte am Bruttopreis ab (> 50 % = rabattfrei)."@de;
    skos:related :Digitales_Produkt, :Physisches_Produkt, :Rabattfrei, :Bruttopreis.
:Bruttopreis a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Bruttopreis"@de;
    skos:altLabel "Gesamtpreis"@de;
    skos:definition "Preis eines Produkts oder Bundles inklusive aller Steuern; Basis für die Berechnung des digitalen Anteils bei gemischten Bundles."@de;
    skos:related :Bundle, :Warenkorbwert.
:Versandpflichtig a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Versandpflichtig"@de;
    skos:definition "Eigenschaft einer Produktkategorie, die angibt, ob der Artikel physisch versandt werden muss."@de;
    skos:broader :Produktkategorie;
    skos:related :Physisches_Produkt, :Versandoption.
:Checkout a skos:Concept;
    skos:inScheme :GlossaryScheme;
    skos:prefLabel "Checkout"@de;
    skos:altLabel "Bestellprozess"@de;
    skos:definition "Abschlussprozess eines Kaufvorgangs, bei dem Zahlungsmethode, Versandoption und Lieferadresse festgelegt werden."@de;
    skos:related :Warenkorb, :Bestellung, :Zahlungsmethode, :Versandoption.
