# =============================================================================
# versand.ttl – Fachdomäne: Versandlogik
# Metadaten siehe Ontologie-Header unten (Abschnitt 1)
# =============================================================================

@prefix :      <https://shop.example.org/glossary#> .
@prefix versand: <https://shop.example.org/versand#> .
@prefix meta:    <https://shop.example.org/meta#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix schema: <https://schema.org/> .
@prefix person: <https://shop.example.org/personen#> .

# -----------------------------------------------------------------------------
# 1. Ontologie-Header
# -----------------------------------------------------------------------------

<https://shop.example.org/versand> a owl:Ontology ;
    dct:title        "Versandlogik – Shop Fachdomäne"@de ;
    dct:description  "OWL-Klassen, Eigenschaften, Instanzen und SHACL-Regeln für die Versandlogik des Shops."@de ;
    dct:created      "2026-05-08"^^xsd:date ;
    dct:source       <inputs/meeting-checkout-versand.md> ;
    dct:contributor  person:Sarah, person:Marco, person:Julia, person:Thomas ;
    dct:date         "2024-03-05"^^xsd:date ;
    owl:imports      <https://shop.example.org/glossary#> .


# =============================================================================
# 2. OWL-Klassen
# =============================================================================
# Hinweis (Prinzip 1 – skos-owl-graph-design Skill):
# Konzepte aus glossary.ttl werden nicht dupliziert. Stattdessen erhalten die
# bestehenden SKOS-Konzepte dort zusätzlich rdf:type owl:Class (RDF Punning).
# Instanzen in dieser Datei referenzieren direkt den :-Namespace.
#
# Neu in versand.ttl: nur Klassen, die im Glossar noch nicht existieren.

versand:Land a owl:Class ;
    rdfs:label   "Land"@de ;
    rdfs:comment "Ein Zielland für Lieferungen, identifiziert per ISO-3166-1-Alpha-2-Code."@de .


# =============================================================================
# 3. OWL-Properties
# =============================================================================

# --- Versandpartner-Eigenschaften --------------------------------------------

versand:liefertIn a owl:ObjectProperty ;
    rdfs:domain  :Versandpartner ;
    rdfs:range   versand:Land ;
    rdfs:label   "liefert in"@de ;
    rdfs:comment "Gibt an, in welche Länder dieser Versandpartner liefert."@de .

versand:lieferzeitMin a owl:DatatypeProperty ;
    rdfs:domain  :Versandpartner ;
    rdfs:range   xsd:integer ;
    rdfs:label   "Lieferzeit min. (Werktage)"@de .

versand:lieferzeitMax a owl:DatatypeProperty ;
    rdfs:domain  :Versandpartner ;
    rdfs:range   xsd:integer ;
    rdfs:label   "Lieferzeit max. (Werktage)"@de .

versand:nurFuerSperrgut a owl:DatatypeProperty ;
    rdfs:domain  :Versandpartner ;
    rdfs:range   xsd:boolean ;
    rdfs:label   "nur für Sperrgut"@de ;
    rdfs:comment "True wenn dieser Partner ausschließlich für Möbel/Sperrgut eingesetzt wird."@de .

# --- Versandoption-Eigenschaften --------------------------------------------

versand:aufpreis a owl:DatatypeProperty ;
    rdfs:domain  :Versandoption ;
    rdfs:range   xsd:decimal ;
    rdfs:label   "Aufpreis (€)"@de ;
    rdfs:comment "Zusatzkosten dieser Versandoption gegenüber dem Standardversand, in Euro."@de .

versand:istExpressOption a owl:DatatypeProperty ;
    rdfs:domain  :Versandoption ;
    rdfs:range   xsd:boolean ;
    rdfs:label   "ist Express-Option"@de .

versand:verwendetPartner a owl:ObjectProperty ;
    rdfs:domain  :Versandoption ;
    rdfs:range   :Versandpartner ;
    rdfs:label   "verwendet Partner"@de .

# --- Kostenlos-Versand-Schwellenwerte ----------------------------------------

versand:kostenlosAbWarenkorbwert a owl:DatatypeProperty ;
    rdfs:domain  versand:Land ;
    rdfs:range   xsd:decimal ;
    rdfs:label   "kostenloser Versand ab Warenkorbwert (€)"@de ;
    rdfs:comment "Mindestwert des Warenkorbs (in €) für kostenlosen Standardversand in dieses Land."@de .

# --- Ländersperre-Eigenschaften ----------------------------------------------

versand:gesperrteKategorie a owl:ObjectProperty ;
    rdfs:domain  :Landerbeschrankung ;
    rdfs:range   skos:Concept ;
    rdfs:label   "gesperrte Kategorie"@de ;
    rdfs:comment "Produktkategorie, die von dieser Sperre betroffen ist."@de .

versand:gesperrtFuerLand a owl:ObjectProperty ;
    rdfs:domain  :Landerbeschrankung ;
    rdfs:range   versand:Land ;
    rdfs:label   "gesperrt für Land"@de .

versand:sperrgrund a owl:DatatypeProperty ;
    rdfs:domain  :Landerbeschrankung ;
    rdfs:range   xsd:string ;
    rdfs:label   "Sperrgrund"@de .

versand:skuUeberschreibungMoeglich a owl:DatatypeProperty ;
    rdfs:domain  :Landerbeschrankung ;
    rdfs:range   xsd:boolean ;
    rdfs:label   "SKU-spezifische Überschreibung möglich"@de ;
    rdfs:comment "Entscheidung aus Meeting: kategoriebasiert, aber SKU-Überschreibung erlaubt."@de .

# --- Produkt-Versandpflicht --------------------------------------------------

versand:istVersandpflichtig a owl:DatatypeProperty ;
    rdfs:range   xsd:boolean ;
    rdfs:label   "ist versandpflichtig"@de ;
    rdfs:comment "False für digitale Produkte – muss im System explizit gesetzt sein (Meeting-Entscheidung)."@de .


# =============================================================================
# 4. Instanzen
# =============================================================================

# --- Länder ------------------------------------------------------------------

versand:DE a versand:Land ;
    rdfs:label                         "Deutschland"@de ;
    schema:identifier                  "DE" ;
    versand:kostenlosAbWarenkorbwert   49.00 .

versand:AT a versand:Land ;
    rdfs:label  "Österreich"@de ;
    schema:identifier "AT" ;
    versand:kostenlosAbWarenkorbwert   99.00 ;
    dct:description  "Schwellenwert 99 € noch nicht final bestätigt (Thomas, Deadline 2024-03-15)."@de .

versand:CH a versand:Land ;
    rdfs:label  "Schweiz"@de ;
    schema:identifier "CH" ;
    versand:kostenlosAbWarenkorbwert   99.00 ;
    dct:description  "Schwellenwert 99 € noch nicht final bestätigt (Thomas, Deadline 2024-03-15)."@de .

versand:UK a versand:Land ;
    rdfs:label  "Vereinigtes Königreich"@de ;
    schema:identifier "GB" .

# --- Versandpartner ----------------------------------------------------------

versand:DHL_Standard a :Versandpartner ;
    rdfs:label            "DHL Standard"@de ;
    versand:lieferzeitMin 2 ;
    versand:lieferzeitMax 4 ;
    versand:nurFuerSperrgut false ;
    versand:liefertIn     versand:DE, versand:AT, versand:CH .

versand:DHL_Express a :Versandpartner ;
    rdfs:label            "DHL Express"@de ;
    versand:lieferzeitMin 1 ;
    versand:lieferzeitMax 1 ;
    versand:nurFuerSperrgut false ;
    versand:liefertIn     versand:DE .

versand:DPD a :Versandpartner ;
    rdfs:label            "DPD"@de ;
    rdfs:comment          "Kein Express-Service verfügbar."@de ;
    versand:lieferzeitMin 3 ;
    versand:lieferzeitMax 5 ;
    versand:nurFuerSperrgut false ;
    dct:description       "Liefert EU gesamt – Länderliste noch nicht vollständig als Instanzen erfasst."@de ;
    dct:source            <inputs/meeting-checkout-versand.md> .

versand:SpeditionMuller a :Versandpartner ;
    rdfs:label              "Spedition Müller"@de ;
    rdfs:comment            "Ausschließlich für Möbel und Sperrgut (Kategorie :Mobel). Lieferzeit variabel."@de ;
    versand:nurFuerSperrgut true ;
    versand:liefertIn       versand:DE ;
    dct:source              <inputs/meeting-checkout-versand.md> .

# --- Versandoptionen ---------------------------------------------------------

versand:Option_DHL_Standard a :Versandoption ;
    rdfs:label              "DHL Standardversand"@de ;
    versand:verwendetPartner versand:DHL_Standard ;
    versand:aufpreis         0.00 ;
    versand:istExpressOption false .

versand:Option_DHL_Express a :Versandoption ;
    rdfs:label              "DHL Express (1 Werktag)"@de ;
    versand:verwendetPartner versand:DHL_Express ;
    versand:aufpreis         6.90 ;
    versand:istExpressOption true .

versand:Option_DPD a :Versandoption ;
    rdfs:label              "DPD EU-Versand"@de ;
    versand:verwendetPartner versand:DPD ;
    versand:aufpreis         0.00 ;
    versand:istExpressOption false .

versand:Option_Spedition a :Versandoption ;
    rdfs:label              "Spedition Müller (Sperrgut)"@de ;
    versand:verwendetPartner versand:SpeditionMuller ;
    versand:aufpreis         0.00 ;
    versand:istExpressOption false ;
    dct:description         "Aufpreis wurde im Meeting nicht genannt, Wert 0.00 ist Platzhalter."@de .

# --- Ländersperren -----------------------------------------------------------

versand:Sperre_Messer_UK a :Landerbeschrankung ;
    rdfs:label                         "Sperre: Messer & Werkzeug → UK"@de ;
    versand:gesperrteKategorie         :Haushalt ;
    versand:gesperrtFuerLand           versand:UK ;
    versand:sperrgrund                 "Zollbeschränkungen post-Brexit"@de ;
    versand:skuUeberschreibungMoeglich true ;
    dct:description                    "Kategoriebasiert (Haushalt inkl. Unterkategorien); SKU-spezifische Überschreibung möglich. Entschieden im Meeting 2024-03-05."@de ;
    dct:contributor                    person:Julia, person:Marco ;
    dct:source                         <inputs/meeting-checkout-versand.md> .

versand:Sperre_Lebensmittel a :Landerbeschrankung ;
    rdfs:label                         "Sperre: Lebensmittel – nur DE und AT"@de ;
    versand:gesperrteKategorie         :Lebensmittel ;
    versand:sperrgrund                 "Exportbeschränkungen – nur DE und AT erlaubt"@de ;
    versand:skuUeberschreibungMoeglich true ;
    dct:description                    "Positivliste: erlaubt nur nach DE und AT. Alle anderen Länder sind implizit gesperrt."@de ;
    dct:source                         <inputs/meeting-checkout-versand.md> .


# =============================================================================
# 5. SHACL-Shapes (Geschäftsregeln)
# =============================================================================

# -----------------------------------------------------------------------------
# 5a. Versandpartner-Zuordnung:
#     Sperrgut-Artikel (Kategorie :Mobel) müssen Spedition Müller verwenden
# -----------------------------------------------------------------------------

versand:SperrgutVersandShape a sh:NodeShape ;
    sh:targetClass   :Versandoption ;
    rdfs:label       "Regel: Sperrgut nur über Spedition Müller"@de ;
    rdfs:comment     "Wenn eine Versandoption für Möbel/Sperrgut eingesetzt wird, muss sie Spedition Müller verwenden."@de ;
    dct:source   <inputs/meeting-checkout-versand.md> ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Möbel/Sperrgut-Bestellungen dürfen nur über Spedition Müller versendet werden."@de ;
        sh:severity sh:Violation ;
        sh:prefixes <https://shop.example.org/versand> ;
        sh:select """
            PREFIX versand: <https://shop.example.org/versand#>
            PREFIX :        <https://shop.example.org/glossary#>
            SELECT $this
            WHERE {
                $this versand:verwendetPartner ?partner .
                ?partner versand:nurFuerSperrgut false .
                # Diese Option wird für eine Sperrgut-Bestellung verwendet
                ?bestellung versand:hatVersandoption $this ;
                            versand:enthaeltKategorie :Mobel .
            }
        """ ;
    ] .

# -----------------------------------------------------------------------------
# 5b. Kostenloser Versand:
#     Jede Versandoption muss einen nicht-negativen Aufpreis haben
# -----------------------------------------------------------------------------

versand:AufpreisShape a sh:NodeShape ;
    sh:targetClass  :Versandoption ;
    rdfs:label      "Regel: Aufpreis nicht negativ"@de ;
    sh:property [
        sh:path     versand:aufpreis ;
        sh:minCount 1 ;
        sh:minInclusive 0.00 ;
        sh:datatype xsd:decimal ;
        sh:message  "Jede Versandoption muss einen Aufpreis ≥ 0,00 € haben."@de ;
        sh:severity sh:Violation ;
    ] .

# -----------------------------------------------------------------------------
# 5c. Digitale Produkte → kein Versand
#     Instanzen von :Digitales_Produkt dürfen nicht versandpflichtig sein
# -----------------------------------------------------------------------------

versand:DigitalesProduktKeinVersandShape a sh:NodeShape ;
    sh:targetClass  :Digitales_Produkt ;
    rdfs:label      "Regel: Digitales Produkt ist nie versandpflichtig"@de ;
    rdfs:comment    "Explizit im Meeting gefordert: auch wenn offensichtlich, muss es im System gesetzt sein."@de ;
    dct:source      <inputs/meeting-checkout-versand.md> ;
    dct:contributor person:Julia ;
    sh:property [
        sh:path     versand:istVersandpflichtig ;
        sh:hasValue false ;
        sh:minCount 1 ;
        sh:message  "Digitale Produkte müssen versandpflichtig=false gesetzt haben."@de ;
        sh:severity sh:Violation ;
    ] .

# -----------------------------------------------------------------------------
# 5d-1. Ländersperre: Lebensmittel nur nach DE und AT
# -----------------------------------------------------------------------------

versand:LebensmittelLandShape a sh:NodeShape ;
    sh:targetClass  :Lebensmittel ;
    rdfs:label      "Regel: Lebensmittel nur nach DE und AT lieferbar"@de ;
    dct:source      <inputs/meeting-checkout-versand.md> ;
    dct:contributor person:Julia ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Lebensmittel dürfen nur nach Deutschland (DE) oder Österreich (AT) geliefert werden."@de ;
        sh:severity sh:Violation ;
        sh:prefixes <https://shop.example.org/versand> ;
        sh:select """
            PREFIX versand: <https://shop.example.org/versand#>
            PREFIX schema:  <https://schema.org/>
            SELECT $this ?land
            WHERE {
                ?bestellung versand:enthaeltKategorie $this ;
                            versand:liefertNachLand   ?land .
                FILTER(?land NOT IN (versand:DE, versand:AT))
            }
        """ ;
    ] .

# -----------------------------------------------------------------------------
# 5d-2. Ländersperre: Messer & Werkzeug nicht nach UK
#        (Unterkategorie Haushalt – kategoriebasiert laut Meeting-Entscheidung)
# -----------------------------------------------------------------------------

versand:HaushaltUKSperreShape a sh:NodeShape ;
    sh:targetClass  :Haushalt ;
    rdfs:label      "Regel: Haushalt/Messer & Werkzeug nicht nach UK"@de ;
    dct:source      <inputs/meeting-checkout-versand.md> ;
    dct:contributor person:Julia ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Produkte der Kategorie Haushalt (inkl. Messer & Werkzeug) dürfen nicht nach UK (GB) geliefert werden."@de ;
        sh:severity sh:Violation ;
        sh:prefixes <https://shop.example.org/versand> ;
        sh:select """
            PREFIX versand: <https://shop.example.org/versand#>
            SELECT $this
            WHERE {
                ?bestellung versand:enthaeltKategorie $this ;
                            versand:liefertNachLand   versand:UK .
            }
        """ ;
    ] .

# -----------------------------------------------------------------------------
# 5e. Express-Versand nur nach DE
#     DHL Express liefert laut Partnerliste ausschließlich nach DE
# -----------------------------------------------------------------------------

versand:ExpressNurDEShape a sh:NodeShape ;
    sh:targetClass  :Versandoption ;
    rdfs:label      "Regel: Express-Versand nur nach Deutschland verfügbar"@de ;
    dct:source      <inputs/meeting-checkout-versand.md> ;
    dct:contributor person:Julia ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Express-Versand (DHL Express) ist nur für Lieferungen nach Deutschland (DE) verfügbar."@de ;
        sh:severity sh:Violation ;
        sh:prefixes <https://shop.example.org/versand> ;
        sh:select """
            PREFIX versand: <https://shop.example.org/versand#>
            SELECT $this ?land
            WHERE {
                $this versand:istExpressOption true ;
                      versand:verwendetPartner ?partner .
                ?bestellung versand:hatVersandoption $this ;
                            versand:liefertNachLand   ?land .
                FILTER(?land != versand:DE)
            }
        """ ;
    ] .


# =============================================================================
# 6. Offene Punkte (als Annotationen im Graphen dokumentiert)
# =============================================================================

versand:OffenerPunkt_AT_CH_Schwellenwert a owl:NamedIndividual, meta:OffenerPunkt ;
    rdfs:label        "Offener Punkt: Kostenlos-Versand-Schwellenwert AT/CH"@de ;
    rdfs:comment      "Thomas prüft ob 99 € für AT und CH korrekt ist. Entscheidung stand zum Meeting-Zeitpunkt (2024-03-05) noch aus. Deadline: 2024-03-15."@de ;
    dct:created       "2024-03-05"^^xsd:date ;
    dct:source        "inputs/meeting-checkout-versand.md" ;
    meta:scopeStatus  "offen" ;
    meta:betrifft     versand:AT, versand:CH .

versand:OffenerPunkt_Spedition_Preis a owl:NamedIndividual, meta:OffenerPunkt ;
    rdfs:label        "Offener Punkt: Preis Spedition Müller"@de ;
    rdfs:comment      "Der Aufpreis für Spedition Müller (Sperrgut) wurde im Meeting nicht genannt und ist im System noch nicht hinterlegt."@de ;
    dct:created       "2024-03-05"^^xsd:date ;
    meta:scopeStatus  "offen" ;
    meta:betrifft     versand:Option_Spedition .

versand:OffenerPunkt_DPD_Lander a owl:NamedIndividual, meta:OffenerPunkt ;
    rdfs:label        "Offener Punkt: DPD Länderliste EU"@de ;
    rdfs:comment      "DPD liefert 'EU gesamt' – die vollständige Länderliste ist noch nicht als Instanzen im Graphen erfasst."@de ;
    dct:created       "2026-05-08"^^xsd:date ;
    meta:scopeStatus  "offen" ;
    meta:betrifft     versand:DPD .
