@prefix :     <https://example.org/domain#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# Beispielkonzept – löschen oder ersetzen

:Beispielkonzept
    a skos:Concept, owl:Class ;
    skos:prefLabel    "Beispielkonzept"@de ;
    skos:definition   "Platzhalter – durch echte Domänenbegriffe ersetzen."@de ;
    skos:inScheme     <https://example.org/domain#> ;
    skos:topConceptOf <https://example.org/domain#> .
