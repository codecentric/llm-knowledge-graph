@prefix app:  <https://shop.example.org/apps#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

app:Versand
    a owl:NamedIndividual, app:App ;
    rdfs:label       "Versanddomäne"@de ;
    dct:description  "Carrier, Versandoptionen, Länderbeschränkungen und Lieferzeiten – tabellarisch und als Graphansicht."@de ;
    app:url          "apps/versand.html"^^xsd:anyURI ;
    app:icon         "🚚" ;
    app:badgeVariant "success" ;
    app:badgeLabel   "Versand · Regeln" ;
    app:sortOrder    2 .
