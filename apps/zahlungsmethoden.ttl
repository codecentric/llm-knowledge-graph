@prefix app:  <https://shop.example.org/apps#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

app:Zahlungsmethoden
    a owl:NamedIndividual, app:App ;
    rdfs:label       "Zahlungsmethoden"@de ;
    dct:description  "Aktive Zahlungsmethoden, Zahlungsregeln und Länderverfügbarkeit – tabellarisch und als Graphansicht."@de ;
    app:url          "apps/zahlungsmethoden.html"^^xsd:anyURI ;
    app:icon         "💳" ;
    app:badgeVariant "neutral" ;
    app:badgeLabel   "Zahlung · Regeln" ;
    app:sortOrder    3 .
