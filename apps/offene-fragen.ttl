@prefix app:  <https://shop.example.org/apps#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

app:OffeneFragen
    a owl:NamedIndividual, app:App ;
    rdfs:label       "Offene Fragen"@de ;
    dct:description  "Ungeklärte Anforderungen, Widersprüche und fehlende Daten im Knowledge Graph – priorisiert nach Schwere."@de ;
    app:url          "apps/offene-fragen.html"^^xsd:anyURI ;
    app:icon         "❓" ;
    app:badgeVariant "warning" ;
    app:badgeLabel   "Qualität · Lücken" ;
    app:sortOrder    4 .
