@prefix app:  <https://shop.example.org/apps#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

app:Glossar
    a owl:NamedIndividual, app:App ;
    rdfs:label       "Fachglossar"@de ;
    dct:description  "Alle Konzepte des Shop-Wissengraphen als interaktives Netzwerk – Definitionen, Beziehungen und Kategorien."@de ;
    app:url          "apps/glossar.html"^^xsd:anyURI ;
    app:icon         "📚" ;
    app:badgeVariant "primary" ;
    app:badgeLabel   "Glossar · Ontologie" ;
    app:sortOrder    1 .
